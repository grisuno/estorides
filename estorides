#!/usr/bin/env bash
# estorides launcher.
# Thin shim that delegates to the installed console script. Falls back to
# the module form if the package is not on PATH.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if command -v estorides >/dev/null 2>&1; then
    exec estorides "$@"
fi

if [ -d env ]; then
    # shellcheck disable=SC1091
    source env/bin/activate
fi
exec python3 estorides_cli.py "$@"
