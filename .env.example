# Estorides — environment variables (optional)
# Copy this file to `.env` and fill the keys you have. Anything you leave
# blank falls back to the free / no-key version of the corresponding source.
#
# OPSEC
# -----
# ESTORIDES_ALLOWED_HOSTS=    suffix-matched allowlist. When set, only these
#                             hosts may be contacted (egress lockdown).
# ESTORIDES_TRUST_PROXY=1     trust X-Forwarded-For for client IP detection.
#                             Only enable when behind a reverse proxy you
#                             control. Otherwise rate limiting is bypassable.
#
# Web hardening (production)
# --------------------------
# ESTORIDES_CORS_ORIGINS=     comma-separated list, e.g.
#                             "https://app.example.com,https://ops.example.com"
# ESTORIDES_HSTS=1            emit Strict-Transport-Security. Only behind TLS.
# ESTORIDES_FORCE_HTTPS=1     308 redirect http -> https. Only behind TLS.
# ESTORIDES_MAX_BODY_BYTES=1048576   per-request JSON / form body cap (1 MiB)
# ESTORIDES_CSP=              override the Content-Security-Policy string.
#
# Concurrency / runtime
# ---------------------
# ESTORIDES_HOST=127.0.0.1    bind address for the web server.
# ESTORIDES_PORT=5050         bind port.
# ESTORIDES_DEBUG=0           NEVER set to 1 in production (RCE).
# ESTORIDES_PARALLEL=8        default parallel sources per run.
# ESTORIDES_TIMEOUT=8.0       per-source HTTP timeout seconds.
# ESTORIDES_DEADLINE=30.0     hard wall-clock cap for a single run.
# ESTORIDES_CACHE_TTL=900     response cache TTL in seconds (15 min default).
#
# LLM backends
# ------------
# Pick whichever you have. The resolver tries ollama -> openrouter ->
# anthropic -> openai -> stub, in that order. With none set, the engine
# returns a templated stub analysis (still useful, just not generated).
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# Per-source API keys (only needed for the corresponding YAMLs to activate)
# -----------------------------------------------------------------------
# SHODAN_API_KEY=             shodan_internetdb / shodan host
# VIRUSTOTAL_API_KEY=         vt_ip / vt_domain / vt_file + graph expansion
# CENSYS_API_ID=
# CENSYS_API_SECRET=
# HUNTER_API_KEY=             hunter email enrich
# INTELX_API_KEY=             intelligencex
# ABUSEIPDB_API_KEY=          abuseipdb
# GREYNOISE_API_KEY=          greynoise community / enterprise
# WIGLE_API_NAME=
# WIGLE_API_TOKEN=
# PSBDMP_API_KEY=             psbdmp authenticated
# DEHASHED_API_KEY=           dehashed
# DEHASHED_USERNAME=
# SCALEVECTOR_API_KEY=        scalevector
# IPINFO_TOKEN=               ipinfo
# PHONEBOOK_API_KEY=          phonebook
# TINYEye_API_KEY=            tineye reverse image
# MACVENDORS_API_KEY=         macvendors
# TIMEZONEDB_API_KEY=         timezonedb
# OPENWEATHER_API_KEY=        openweather geocoding
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=          tgstat
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=       reddit
# GITHUB_TOKEN=               github (raises rate limit 60/hr -> 5000/hr)
# GOOGLE_CACHE_KEY=           google cache mirror (optional)
# NVD_API_KEY=                nvd cve (raises rate limit)
#
# OPSEC anonymisation
# -------------------
# ESTORIDES_PROXY_POOL=       comma-separated HTTP(S) proxies. Cycled per
#                             request to spread the origin.
# ESTORIDES_TOR_SOCKS=        socks5://127.0.0.1:9050
#                              (requires aiohttp_socks)
